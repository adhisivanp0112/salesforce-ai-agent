# ============================================
# SALESFORCE AUTHENTICATION CONFIGURATION
# ============================================

# Choose authentication method:
# - 'false' = Use SF CLI (for development)
# - 'true'  = Use Username/Password (for production)
SF_USE_PASSWORD_AUTH=false

# ============================================
# METHOD 1: SF CLI AUTHENTICATION (Default)
# ============================================
# Used when SF_USE_PASSWORD_AUTH=false
SF_ORG_ALIAS=myverbis

# ============================================
# METHOD 2: USERNAME/PASSWORD AUTHENTICATION
# ============================================
# Used when SF_USE_PASSWORD_AUTH=true

# Your Salesforce username
SF_USERNAME=test-kildedmurv0h@example.com

# Your Salesforce password
SF_PASSWORD=YourPassword123

# Your Salesforce security token (get from Setup > My Personal Information > Reset Security Token)
# Leave empty if not required (e.g., trusted IP ranges)
SF_SECURITY_TOKEN=

# Login URL:
# - Production/Developer: https://login.salesforce.com
# - Sandbox: https://test.salesforce.com
SF_LOGIN_URL=https://login.salesforce.com

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
FRONTEND_URL=http://localhost:3000

# ============================================
# AI CONFIGURATION (UNIVERSAL - Works with ANY API!)
# ============================================

# NOTE: You DON'T need to set AI_PROVIDER anymore!
# Just add your API keys below and select provider from UI dropdown

# Legacy (optional - only used if UI doesn't specify provider)
# AI_PROVIDER=groq
# AI_API_KEY=your_api_key_here

# ============================================
# OPTION 2A: Individual Provider Keys (Traditional)
# ============================================
# Groq (FREE, FAST - Recommended!)
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# xAI / Grok (Elon Musk's AI)
XAI_API_KEY=xai-your_xai_key_here

# Cohere
COHERE_API_KEY=your_cohere_key_here

# ============================================
# OPTION 2B: JSON Array Format (Centralized)
# ============================================
# Define all your providers and API keys in ONE JSON array
# Format: [{"provider":"name","key":"your_api_key"}]
# This overrides individual keys above if set

API_PROVIDERS=[{"provider":"groq","key":"gsk_your_groq_key_here"},{"provider":"openai","key":"sk-your_openai_key_here"},{"provider":"anthropic","key":"sk-ant-your_anthropic_key_here"},{"provider":"xai","key":"xai-your_xai_key_here"},{"provider":"cohere","key":"your_cohere_key_here"}]

# Example with real keys (replace with yours):
# API_PROVIDERS=[{"provider":"groq","key":"gsk_abc123xyz789"},{"provider":"openai","key":"sk-proj-xyz789abc123"}]

# ============================================
# Legacy Provider Keys (Optional)
# ============================================
# Google Gemini (legacy handler)
GOOGLE_API_KEY=AIza_your_google_key_here

# Mistral AI
MISTRAL_API_KEY=your_mistral_key_here

# Perplexity AI
PERPLEXITY_API_KEY=pplx-your_perplexity_key_here

# ============================================
# HOW IT WORKS:
# ============================================
# 1. Add your API keys above (JSON array OR individual variables)
# 2. Users select provider from UI dropdown
# 3. Backend automatically uses the correct API key
# 4. NO NEED to set AI_PROVIDER in .env!
#
# Priority: If API_PROVIDERS is set, it takes precedence over individual keys
#
# Users can dynamically switch between providers using the UI dropdown

# ============================================
# Optional: Override default models
# ============================================
# AI_MODEL=llama-3.1-70b-versatile  (for Groq)
# AI_MODEL=gpt-4o-mini               (for OpenAI)
# AI_MODEL=claude-3-5-sonnet-20241022 (for Anthropic)

# ============================================
# GOOGLE GEMINI AI CONFIGURATION
# ============================================
# Get your free API key from: https://aistudio.google.com/app/apikey
# Free tier includes:
# - 15 requests per minute (RPM)
# - 1 million tokens per minute (TPM)
# - 1,500 requests per day (RPD)
#
# To avoid rate limits:
# 1. Wait a few minutes between heavy usage
# 2. Consider upgrading to paid tier for higher limits
# 3. Monitor your usage at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# HUGGING FACE AI CONFIGURATION
# ============================================
# Get your free API key from: https://huggingface.co/settings/tokens
# Free tier: Access to thousands of models, no daily limits
#
# Simply change HUGGINGFACE_MODEL to use any model:
#
# Recommended Models:
# - Salesforce/xLAM-2-1b-fc-r (Function calling - BEST for Salesforce)
# - Salesforce/xLAM-1b-fc-r (Function calling - smaller)
# - mistralai/Mistral-7B-Instruct-v0.1 (General purpose)
# - meta-llama/Meta-Llama-3-8B-Instruct (Requires access request)
#
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=Salesforce/xLAM-2-1b-fc-r

# ============================================
# DATABASE CONFIGURATION (OPTIONAL)
# ============================================
# Enable database to store chat history with pgvector for semantic search
# Set to 'true' to enable, 'false' to disable (app works without database)
USE_DATABASE=false

# PostgreSQL connection details (when USE_DATABASE=true)
# These match the docker-compose.yml configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=salesforce_chat
DB_USER=admin
DB_PASSWORD=admin123

# Note: To start the database, run: docker-compose up -d
# Access pgAdmin at: http://localhost:5050
# pgAdmin credentials: admin@salesforce.com / admin123



lsof -ti:3001 | xargs kill -9
cd /Users/home/Desktop/salesforce-admin-app/backend
npm start